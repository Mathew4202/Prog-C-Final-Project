<UserControl x:Class="Final_Project.Pages.DetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Background="#F4F4F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#171717" Grid.Row="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Movie Details"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <Button Content="Home"
                        Click="HomeButton_Click"
                        Grid.Column="1"
                        Width="90"
                        Height="38"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="White"
                        Foreground="#171717"/>

                <Button Content="Back to Movies"
                        Click="BackButton_Click"
                        Grid.Column="2"
                        Width="130"
                        Height="38"
                        VerticalAlignment="Center"
                        Background="White"
                        Foreground="#171717"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                <Border Background="White"
                        CornerRadius="14"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="18"
                        Margin="0,0,0,18">
                    <StackPanel>
                        <TextBlock Text="{Binding Movie.PrimaryTitle}"
                                   FontSize="30"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="Movie Information"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Original Title: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.OriginalTitle}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Type: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.TitleType}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Adult: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.IsAdult}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Start Year: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.StartYear}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="End Year: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.EndYear}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="Runtime: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.RuntimeMinutes}"/>
                            <TextBlock Text=" minutes"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,8">
                            <TextBlock Text="IMDB Rating: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.AverageRating}"/>
                        </WrapPanel>

                        <WrapPanel Margin="0,0,0,12">
                            <TextBlock Text="Votes: " FontWeight="Bold"/>
                            <TextBlock Text="{Binding Movie.NumVotes}"/>
                        </WrapPanel>

                        <TextBlock Text="Directors:"
                                   FontWeight="Bold"
                                   Margin="0,4,0,6"/>

                        <ItemsControl ItemsSource="{Binding Movie.Directors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Margin="0,0,0,4"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Background="White"
                        CornerRadius="14"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="18">
                    <StackPanel>
                        <TextBlock Text="Reviews"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Margin="0,0,0,12"/>

                        <ListBox ItemsSource="{Binding Reviews}" Height="250" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#E5E7EB"
                                            BorderThickness="0,0,0,1"
                                            Padding="8">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding ReviewerName}" FontWeight="Bold"/>
                                                <TextBlock Text=" - "/>
                                                <TextBlock Text="{Binding ReviewScore}"/>
                                                <TextBlock Text="/5"/>
                                            </StackPanel>

                                            <TextBlock Text="{Binding ReviewText}" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding ReviewDate}" FontSize="10" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Padding="18">
                <StackPanel>
                    <TextBlock Text="Leave a review"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <TextBlock Text="Your Name"
                               FontWeight="SemiBold"
                               Margin="0,0,0,4"/>

                    <TextBox Text="{Binding ReviewerName, UpdateSourceTrigger=PropertyChanged}" 
                             Height="36"
                             Padding="8"
                             Margin="0,0,0,14"/>

                    <TextBlock Text="Your Rating"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Button x:Name="Star1" Content="★" FontSize="26" Width="42" Height="42" Tag="1"
                                Background="Transparent" BorderBrush="#D1D5DB"
                                Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" MouseLeave="StarButton_MouseLeave"/>
                        <Button x:Name="Star2" Content="★" FontSize="26" Width="42" Height="42" Tag="2"
                                Background="Transparent" BorderBrush="#D1D5DB"
                                Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" MouseLeave="StarButton_MouseLeave"/>
                        <Button x:Name="Star3" Content="★" FontSize="26" Width="42" Height="42" Tag="3"
                                Background="Transparent" BorderBrush="#D1D5DB"
                                Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" MouseLeave="StarButton_MouseLeave"/>
                        <Button x:Name="Star4" Content="★" FontSize="26" Width="42" Height="42" Tag="4"
                                Background="Transparent" BorderBrush="#D1D5DB"
                                Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" MouseLeave="StarButton_MouseLeave"/>
                        <Button x:Name="Star5" Content="★" FontSize="26" Width="42" Height="42" Tag="5"
                                Background="Transparent" BorderBrush="#D1D5DB"
                                Click="StarButton_Click" MouseEnter="StarButton_MouseEnter" MouseLeave="StarButton_MouseLeave"/>
                    </StackPanel>

                    <TextBlock Text="Your Review"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>

                    <TextBox Height="140"
                             Padding="10"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Text="{Binding ReviewText, UpdateSourceTrigger=PropertyChanged}"/>

                    <Button Content="Submit Review"
                            Width="140"
                            Height="38"
                            Margin="0,14,0,0"
                            Background="#171717"
                            Foreground="White"
                            BorderBrush="#171717"
                            Click="SubmitReviewButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>