<UserControl x:Class="Final_Project.Pages.Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1100">

    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#1F1F1F" Grid.Row="0">
            <Grid>
                <TextBlock Text="Movie Review Application"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="20">

                <TextBlock Text="Welcome to the Movie Review Application"
                           FontSize="28"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,20"/>

                <TextBlock Text="This application allows users to browse movies, explore directors, view movie details, and submit reviews."
                           FontSize="16"
                           TextWrapping="Wrap"
                           Margin="0,0,0,15"/>

                <TextBlock Text="You can explore these main pages:"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <TextBlock Text="• Home Page"
                           FontSize="15"
                           Margin="0,0,0,5"/>

                <TextBlock Text="• Movies Page"
                           FontSize="15"
                           Margin="0,0,0,5"/>

                <TextBlock Text="• Directors Page"
                           FontSize="15"
                           Margin="0,0,0,5"/>

                <TextBlock Text="• Details and Review Page"
                           FontSize="15"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Use the button on the right to start exploring the movie database."
                           FontSize="15"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <Border Background="White"
                        Padding="25"
                        CornerRadius="10"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        Width="260">
                    <StackPanel>
                        <TextBlock Text="Start Here"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                        <Button x:Name="BrowseMoviesButton"
                                   Content="Go to Movies"
                                    Height="45"
                                    FontSize="16"
                                    FontWeight="SemiBold"
                                    Click="BrowseMoviesButton_Click"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>