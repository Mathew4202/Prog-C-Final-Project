<UserControl x:Class="Final_Project.Pages.MoviesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1028.116">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Navbar -->
            <RowDefinition Height="*"/>
            <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- =======================
             NAVBAR
             ======================= -->
        <Grid Grid.Row="0" Height="60">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Title -->
            <TextBlock Text="Movies"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <!-- Search Bar -->
            <TextBox
                     Width="360"
                     HorizontalAlignment="Left"
                     VerticalAlignment="Center"
                     Text="{Binding SearchText}"
                     ToolTip="Search movies..." Grid.ColumnSpan="2" Margin="141,0,0,0"/>

            <Button Grid.Column="1"
                    Content="Search"
                    Command="{Binding SearchCommand}"
                    Width="80"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="313,0,0,0"/>

            <!-- Home Button -->
            <Button Content="Home"
                    Grid.Column="2"
                    Width="80"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,100,0"/>

            <!-- Directors Button (BACK IN NAVBAR) -->
            <Button Content="Directors"
                    Grid.Column="2"
                    Width="100"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Command="{Binding GoToDirectorsCommand}"/>
        </Grid>

        <!-- =======================
             MAIN CONTENT
             ======================= -->
        <Grid Grid.Row="1" Margin="0 20 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <!-- Movie list -->
                <ColumnDefinition Width="1*"/>
                <!-- Filters -->
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDE: MOVIE LIST -->
            <ScrollViewer Grid.Column="0">
                <ItemsControl ItemsSource="{Binding Movies}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="Gray"
                                    BorderThickness="1"
                                    Padding="10"
                                    CornerRadius="5"
                                    Margin="0 0 0 10">

                                <StackPanel>

                                    <TextBlock Text="{Binding PrimaryTitle}"
                                               FontSize="20"
                                               FontWeight="Bold"/>

                                    <TextBlock Text="{Binding StartYear}"
                                               FontSize="14"
                                               Margin="0 5 0 0"/>

                                    <TextBlock Text="Rating:" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding AverageRating}" />

                                    <TextBlock Text="Votes:" FontWeight="Bold" Margin="0 5 0 0"/>
                                    <TextBlock Text="{Binding NumVotes}" />

                                    <!-- BUTTON ROW (NO DIRECTORS BUTTON HERE) -->
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0 10 0 0">

                                        <Button Content="Details"
                                                Width="100"
                                                Height="30"
                                                Command="{Binding DataContext.DetailsCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding TitleId}"/>

                                    </StackPanel>

                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- =======================
                 FILTERS
                 ======================= -->
            <StackPanel Grid.Column="1"
                        Margin="20 0 0 0"
                        VerticalAlignment="Top">

                <!-- Sort by Year -->
                <StackPanel Margin="0 0 0 20">
                    <TextBlock Text="Sort by Year"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="150"
                                  Height="30"
                                  SelectedValue="{Binding SelectedYearSort, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="Ascending"/>
                            <ComboBoxItem Content="Descending"/>
                        </ComboBox>

                        <Button Content="Clear"
                                Width="60"
                                Margin="10,0,0,0"
                                Command="{Binding ClearYearSortCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sort by Rating -->
                <StackPanel Margin="0 0 0 20">
                    <TextBlock Text="Sort by Rating"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="150"
                                  Height="30"
                                  SelectedValue="{Binding SelectedRatingSort, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="Ascending"/>
                            <ComboBoxItem Content="Descending"/>
                        </ComboBox>

                        <Button Content="Clear"
                                Width="60"
                                Margin="10,0,0,0"
                                Command="{Binding ClearRatingSortCommand}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Sort by Votes -->
                <StackPanel Margin="0 0 0 20">
                    <TextBlock Text="Sort by Votes"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0 0 0 5"/>

                    <StackPanel Orientation="Horizontal">
                        <ComboBox Width="150"
                                  Height="30"
                                  SelectedValue="{Binding SelectedVotesSort, Mode=TwoWay}"
                                  SelectedValuePath="Content">
                            <ComboBoxItem Content="Ascending"/>
                            <ComboBoxItem Content="Descending"/>
                        </ComboBox>

                        <Button Content="Clear"
                                Width="60"
                                Margin="10,0,0,0"
                                Command="{Binding ClearVotesSortCommand}"/>
                    </StackPanel>
                </StackPanel>

                <Button Content="Apply Filters"
                        Width="150"
                        Height="35"
                        Command="{Binding ApplyFiltersCommand}"/>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
