<UserControl x:Class="Final_Project.Pages.MoviesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1100">

    <Grid Background="#F4F4F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="#171717" Grid.Row="0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Movies"
                           Foreground="White"
                           FontSize="30"
                           FontWeight="Bold"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBox Width="360"
                             Height="38"
                             Padding="10,6"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="Search movies..."
                             Margin="0,0,10,0"/>
                    <Button Grid.Column="1"
                            Content="Search"
                            Width="90"
                            Height="38"
                            Background="White"
                            Foreground="#171717"
                            Click="SearchButton_Click"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="Home"
                        Width="90"
                        Height="38"
                        Margin="0,0,10,0"
                        VerticalAlignment="Center"
                        Background="White"
                        Foreground="#171717"
                        Click="HomeButton_Click"/>

                <Button Grid.Column="3"
                        Content="Directors"
                        Width="100"
                        Height="38"
                        VerticalAlignment="Center"
                        Background="White"
                        Foreground="#171717"
                        Click="DirectorsButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="1.1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Padding="16"
                    Margin="0,0,18,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Movies}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        Background="#FAFAFA"
                                        Padding="16"
                                        CornerRadius="10"
                                        Margin="0,0,0,14">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel>
                                            <TextBlock Text="{Binding PrimaryTitle}"
                                                       FontSize="24"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap"/>

                                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                <TextBlock Text="Year: "
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding StartYear}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Rating: "
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding AverageRating}"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="Votes: "
                                                           FontWeight="Bold"/>
                                                <TextBlock Text="{Binding NumVotes}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Details"
                                                Width="100"
                                                Height="36"
                                                VerticalAlignment="Bottom"
                                                Margin="16,0,0,0"
                                                Background="#171717"
                                                Foreground="White"
                                                BorderBrush="#171717"
                                                Click="DetailsButton_Click"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="14"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Padding="18"
                    VerticalAlignment="Top">
                <StackPanel>
                    <TextBlock Text="Quick Filters"
                               FontSize="22"
                               FontWeight="Bold"
                               Margin="0,0,0,16"/>

                    <Button Content="Top Rated"
                            Width="150"
                            Height="40"
                            Margin="0,0,0,12"
                            Background="#171717"
                            Foreground="White"
                            BorderBrush="#171717"
                            Click="TopRatedButton_Click"/>

                    <Button Content="Newest"
                            Width="150"
                            Height="40"
                            Background="#171717"
                            Foreground="White"
                            BorderBrush="#171717"
                            Click="NewestButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>